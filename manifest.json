{
  "manifest_version": 3,
  "name": "Quick Currency Converter",
  "description": "Convert between a list of selected currencies from the Chrome toolbar.",
  "version": "1.0.0",
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Currency Converter",
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage"],
  "host_permissions": [
    "https://exchangerate.fun/*",
    "https://api.exchangerate.fun/*",
    "https://api.frankfurter.dev/*"
  ]
}
